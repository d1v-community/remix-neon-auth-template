{
  "type": "module",
  "sideEffects": false,
  "name": "d1v-remix-neon-auth",
  "private": true,
  "description": "D1V foundation template for Remix + Neon passwordless authentication apps.",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit --pretty",
    "typecheck:watch": "tsc --noEmit --watch",
    "db:migrate": "node scripts/migrate.mjs",
    "db:migrate:api": "node scripts/migrate_via_api.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:seed:api": "node scripts/seed_via_api.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "drizzle-orm": "^0.45.2",
    "isbot": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.24",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "^4.2.1"
  },
  "pnpm": {
    "overrides": {
      "undici": "6.25.0",
      "qs": "6.14.2",
      "path-to-regexp": "0.1.13",
      "picomatch": "2.3.2"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
